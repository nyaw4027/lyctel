{
    "build": {
        "builder": "NIXPACKS",
        "nixpacksPlan": {
            "phases": {
                "setup": {
                    "nixPkgs": [
                        "cairo",
                        "pango",
                        "glib",
                        "libffi",
                        "pkg-config"
                    ]
                }
            }
        }
    },
    "deploy": {
        "startCommand": "gunicorn ecommerce.wsgi",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}